rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Monovale — lobby rooms
    match /rooms/{code} {
      allow read, write: if request.auth != null;

      // Voice chat: presence + WebRTC signaling subcollections
      match /voice/{uid} {
        allow read, write: if request.auth != null;
      }
      match /voiceSignal/{pairKey} {
        allow read, write: if request.auth != null;
      }
      // Text chat messages
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Monovale — active games
    match /games/{gameId} {
      allow read, write: if request.auth != null;
    }

    // Monovale — finished game results
    match /gameResults/{resultId} {
      allow read, write: if request.auth != null;
    }

    // Lenda da Bola — online league rooms
    match /lenda-leagues/{code} {
      allow read, write: if request.auth != null;
    }

    // Lenda da Bola — per-player career saves + standings
    match /lenda-saves/{saveId} {
      allow read, write: if request.auth != null;
    }

    // Lendas da Bola — multiplayer board game rooms
    match /lendas-rooms/{code} {
      allow read, write: if request.auth != null;
    }
  }
}
